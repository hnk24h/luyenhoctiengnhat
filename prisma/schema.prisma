// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Language {
  ja
  zh
  ko
  en
  vi
}

enum Subject {
  JLPT
  HSK
  PMP
}

enum UserRole {
  user
  admin
}

enum Skill {
  nghe
  noi
  doc
  viet
  vocab
  grammar
}

enum QuestionType {
  tracnghiem
  dien_tu
  nghe_audio
  ghi_am
  upload_file
}

enum LessonType {
  text
  vocab
  grammar
  audio
}

enum ContentType {
  vocab
  character  // language-agnostic: kanji (ja) | hanzi (zh) | hanja (ko)
  grammar
  example
  phrase
  tone       // tonal marks / pitch accent (vi, zh)
  idiom      // 成語 / 慣用句
}

enum StudyEventType {
  lesson_open
  lesson_complete
  flashcard_review
  exam_start
  exam_finish
  vocab_view
}

enum Difficulty {
  easy
  medium
  hard
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  password          String?
  role              UserRole            @default(user)
  createdAt         DateTime            @default(now())
  sessions          ExamSession[]
  progress          UserProgress[]
  lessonProgress    LessonProgress[]
  flashcardDecks    FlashcardDeck[]
  flashcardProgress FlashcardProgress[]
  savedWords        SavedWord[]
  wordCollections   WordCollection[]
  examPlan          UserExamPlan?
  studyProfile      UserStudyProfile?
  pmpProgress       PMPUserProgress[]
  studyEvents       StudyEvent[]
  courseEnrollments CourseEnrollment[]
  pmpSessions       PMPExamSession[]
}

model UserStudyProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyGoal       Int      @default(12)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserExamPlan {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetLevelCode      String
  examDate             DateTime
  daysLeftAtSave       Int
  weeksLeftAtSave      Int
  examsPerWeek         Int
  studySessionsPerWeek Int
  reviewDays           Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Level {
  id                 String             @id @default(cuid())
  code               String             @unique // N5, N4, N3, N2, N1 | HSK1-HSK6
  name               String
  description        String?
  order              Int                @default(0)
  subject            Subject            @default(JLPT)
  examSets           ExamSet[]
  learningCategories LearningCategory[]
  courses            Course[]
  readingPassages    ReadingPassage[]
  chinesePassages    ChinesePassage[]
}

model ExamSet {
  id          String       @id @default(cuid())
  levelId     String
  level       Level        @relation(fields: [levelId], references: [id])
  skill       Skill
  title       String
  description String?
  timeLimit   Int?         // seconds, null = unlimited
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  questions   Question[]
  sessions    ExamSession[]
  progress    UserProgress[]

  @@index([levelId, skill])
}

model Question {
  id        String   @id @default(cuid())
  examSetId String
  examSet   ExamSet  @relation(fields: [examSetId], references: [id], onDelete: Cascade)
  type      QuestionType
  content   String
  options   Json?    // array of option strings for multiple choice
  answer    String   // correct answer string (or JSON-encoded array for multi-answer)
  explain   String?
  audioUrl  String?
  imageUrl  String?
  order     Int      @default(0)

  @@index([examSetId, order])
}

model ExamSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  examSetId   String
  examSet     ExamSet   @relation(fields: [examSetId], references: [id])
  answers     ExamAnswer[]
  score       Float?
  totalQ      Int       @default(0)
  correctQ    Int       @default(0)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([userId, startedAt])
  @@index([examSetId])
}

model ExamAnswer {
  id         String      @id @default(cuid())
  sessionId  String
  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  answer     String
  isCorrect  Boolean

  @@index([sessionId])
  @@index([questionId])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  examSetId   String
  examSet     ExamSet   @relation(fields: [examSetId], references: [id])
  completed   Boolean   @default(false)
  bestScore   Float?
  attempts    Int       @default(0)
  lastAttempt DateTime?

  @@unique([userId, examSetId])
}

// ─── LEARNING MODULE ─────────────────────────────────────────────────────────

model LearningCategory {
  id          String           @id @default(cuid())
  levelId     String
  level       Level            @relation(fields: [levelId], references: [id])
  skill       Skill
  name        String
  description String?
  icon        String?
  order       Int              @default(0)
  lessons     LearningLesson[]

  @@index([levelId, skill])
}

model LearningLesson {
  id          String           @id @default(cuid())
  categoryId  String
  category    LearningCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title       String
  description String?
  content     String?          // JSON blob for audio/text lessons (listening: ListeningContentPayload; text: markdown)
  type        LessonType       @default(text)
  order       Int              @default(0)
  items       Content[]
  progress    LessonProgress[]
  modules     LessonsOnModule[]

  @@index([categoryId, order])
  @@index([type])
}

model Content {
  id            String         @id @default(cuid())
  lessonId      String
  lesson        LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type          ContentType
  language      Language
  term          String         @map("japanese")
  pronunciation String?        @map("reading")
  audioUrl      String?
  imageUrl      String?
  order         Int            @default(0)
  meanings      ContentMeaning[]
  examples      ContentExample[]
  flashcards    Flashcard[]
  savedBy       SavedWord[]

  @@index([lessonId, type])
  @@index([lessonId, language])
  @@index([term])              // words API: findFirst by term
}

model ContentMeaning {
  id        String  @id @default(cuid())
  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  language  Language
  meaning   String

  @@unique([contentId, language])
}

model ContentExample {
  id                  String  @id @default(cuid())
  contentId           String  @map("learning_item_id")
  content             Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  exampleText         String  @map("example_text")
  translation         String?
  language            Language
  translationLanguage Language? @map("translation_language")

  @@index([contentId])
}

model LessonProgress {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      LearningLesson @relation(fields: [lessonId], references: [id])
  completed   Boolean        @default(false)
  completedAt DateTime?

  @@unique([userId, lessonId])
}

// ─── FLASHCARD MODULE ─────────────────────────────────────────────────────────

model FlashcardDeck {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  color       String      @default("#4F46E5") // accent color for the deck
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cards       Flashcard[]

  @@index([userId])
}

model Flashcard {
  id         String              @id @default(cuid())
  deckId     String
  deck       FlashcardDeck       @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front      String            // question / Japanese word
  back       String            // answer / meaning
  reading    String?           // furigana (optional)
  example    String?           // example sentence
  imageUrl   String?           // optional image URL
  contentId  String?           // optional FK → Content (for system-generated cards)
  contentRef Content?          @relation(fields: [contentId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  order      Int               @default(0)
  progress   FlashcardProgress[] // one record per user (was wrongly singular + @unique(cardId))

  @@index([deckId, order])
  @@index([contentId])
}

model FlashcardProgress {
  id           String    @id @default(cuid())
  cardId       String
  card         Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SM-2 fields
  repetitions  Int       @default(0)   // consecutive correct reviews
  interval     Int       @default(1)   // days until next review
  easeFactor   Float     @default(2.5) // multiplier (min 1.3)
  dueAt        DateTime  @default(now())
  lastReview   DateTime?
  totalReviews Int       @default(0)

  @@unique([userId, cardId]) // FIXED: was @unique(cardId) which blocked multiple users per card
  @@index([userId, dueAt])   // for SRS review queue queries
  @@index([userId, lastReview]) // for activity calendar queries
}

// ─── READING MODULE ───────────────────────────────────────────────────────────

model ReadingPassage {
  id         String   @id @default(cuid())
  title      String                        // Japanese title
  titleVi    String?                       // Vietnamese title
  content    String                        // Full Japanese text
  summary    String?                       // Short Vietnamese summary
  level      String                        // N5 | N4 | N3 | N2 | N1 — kept for simple filtering
  levelId    String?                       // optional FK → Level.id
  levelRef   Level?   @relation(fields: [levelId], references: [id])
  type       String   @default("short")   // "short" | "long" | "news"
  source     String?                       // Source name (e.g. NHK Web Easy)
  sourceUrl  String?
  tags       Json?                         // array of tag strings
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([level, published])
  @@index([published, createdAt])
}

model SavedWord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  context     String?  // sentence the word appeared in
  createdAt   DateTime @default(now())
  collections SavedWordsOnCollections[]

  @@unique([userId, contentId])
}

// ─── WORD COLLECTION (user-defined topic folders) ────────────────────────────

model WordCollection {
  id        String                    @id @default(cuid())
  userId    String
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String                    @default("#4F46E5")
  createdAt DateTime                  @default(now())
  words     SavedWordsOnCollections[]

  @@unique([userId, name])
}

model SavedWordsOnCollections {
  wordId       String
  word         SavedWord      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  collectionId String
  collection   WordCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  addedAt      DateTime       @default(now())

  @@id([wordId, collectionId])
}

// ─── Chinese / HSK Module ─────────────────────────────────────────────────────

model ChinesePassage {
  id           String   @id @default(cuid())
  title        String
  titleVi      String?
  level        String   // HSK1 | HSK2 | … | HSK6 — kept for simple filtering
  levelId      String?  // optional FK → Level.id
  levelRef     Level?   @relation(fields: [levelId], references: [id])
  content      String   // Simplified Chinese text
  pinyin       String?  // Full passage pinyin annotation (JSON or plain)
  translation  String?  // Vietnamese translation
  audioUrl     String?
  topic        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([level])
  @@index([topic])
}

// ─── PMP / PMBOK 6 Module ─────────────────────────────────────────────────────

model PMPKnowledgeArea {
  id          String       @id @default(cuid())
  code        String       @unique // e.g. "integration", "scope", ...
  name        String       // English name
  nameVi      String       // Vietnamese name
  description String?
  order       Int          @default(0)
  processes   PMPProcess[]
}

model PMPProcessGroup {
  id       String       @id @default(cuid())
  code     String       @unique // initiating | planning | executing | monitoring | closing
  name     String
  nameVi   String
  order    Int          @default(0)
  processes PMPProcess[]
}

model PMPProcess {
  id               String           @id @default(cuid())
  knowledgeAreaId  String
  knowledgeArea    PMPKnowledgeArea @relation(fields: [knowledgeAreaId], references: [id])
  processGroupId   String
  processGroup     PMPProcessGroup  @relation(fields: [processGroupId], references: [id])
  name             String
  nameVi           String
  description      String?
  inputs           Json?            // array of strings
  tools            Json?            // array of strings
  outputs          Json?            // array of strings
  keyPoints        String?          // Markdown notes for learners
  order            Int              @default(0)
  examQuestions    PMPExamQuestion[]

  @@index([knowledgeAreaId])
  @@index([processGroupId])
}

model PMPExamQuestion {
  id         String      @id @default(cuid())
  processId  String?
  process    PMPProcess? @relation(fields: [processId], references: [id])
  area       String?     // knowledge area code if question is KA-level
  group      String?     // process group code if question is PG-level
  content    String      // Question text (Vietnamese)
  optionA    String
  optionB    String
  optionC    String
  optionD    String
  answer     String      // "A" | "B" | "C" | "D"
  explain    String?
  difficulty Difficulty  @default(medium)
  tags       Json?       // e.g. ["ITTOs", "Concepts"]
  createdAt  DateTime    @default(now())
  answers    PMPExamAnswer[]

  @@index([area, difficulty])
  @@index([processId])
}

model PMPUserProgress {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeArea       String   // knowledge area code
  questionsAttempted  Int      @default(0)
  questionsCorrect    Int      @default(0)
  updatedAt           DateTime @updatedAt

  @@unique([userId, knowledgeArea])
}

model PMPExamSession {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  areaCode    String?         // null = mixed exam; knowledge area code e.g. "integration"
  answers     PMPExamAnswer[]
  score       Float?
  totalQ      Int             @default(0)
  correctQ    Int             @default(0)
  startedAt   DateTime        @default(now())
  finishedAt  DateTime?

  @@index([userId, startedAt])
}

model PMPExamAnswer {
  id         String          @id @default(cuid())
  sessionId  String
  session    PMPExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   PMPExamQuestion @relation(fields: [questionId], references: [id])
  answer     String          // "A" | "B" | "C" | "D"
  isCorrect  Boolean

  @@index([sessionId])
  @@index([questionId])
}

// ─── ANALYTICS ───────────────────────────────────────────────────────────────
// Tracks every meaningful learning interaction for analytics & streak system.

model StudyEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      StudyEventType
  targetId  String?  // lessonId | flashcardId | examSetId | learningItemId (depending on type)
  targetType String? // lesson | flashcard | exam | item
  score     Float?   // for exam_finish: score %; for flashcard_review: ease rating 1-5
  duration  Int?     // seconds spent
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
}

// ─── COURSE / MODULE LAYER ───────────────────────────────────────────────────
// Optional LMS hierarchy above LearningCategory.
// Level → Course → Module → LearningLesson (existing)
// LearningCategory stays, but a Module can group lessons more explicitly.

model Course {
  id          String           @id @default(cuid())
  levelId     String
  level       Level            @relation(fields: [levelId], references: [id])
  title       String
  description String?
  coverUrl    String?
  order       Int              @default(0)
  published   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  modules     Module[]
  enrollments CourseEnrollment[]
}

model Module {
  id          String           @id @default(cuid())
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int              @default(0)
  // A Module groups existing LearningLessons via a join table:
  lessons     LessonsOnModule[]
}

model LessonsOnModule {
  moduleId  String
  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    LearningLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int            @default(0)

  @@id([moduleId, lessonId])
}

model CourseEnrollment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime @default(now())
  completedAt DateTime?

  @@unique([userId, courseId])
}
